# =============================================================================
# Ecommerce Backend — contoh konfigurasi environment
# Salin menjadi .env lalu isi nilainya:  cp .env.example .env
# =============================================================================

# ---------- Aplikasi ----------
# Opsional. Port HTTP (default 3000).
PORT=3000
# Opsional. development | production
NODE_ENV=development
# Origin web frontend untuk CORS + cookie credentials (pisahkan dengan koma;
# JANGAN wildcard — tidak sah bersama credentials). Mobile/desktop tanpa
# Origin header tidak terpengaruh.
CORS_ORIGINS=http://localhost:3001

# ---------- Database (WAJIB) ----------
# PostgreSQL — dipakai aplikasi & drizzle-kit (migrasi).
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce

# ---------- Redis / BullMQ (WAJIB) ----------
# Broker queue (pipeline invoice PDF+email, auto-expire order).
# Jalankan lokal: docker compose up -d
REDIS_HOST=localhost
REDIS_PORT=6379
# Opsional.
REDIS_PASSWORD=
REDIS_DB=

# ---------- Storage R2/S3 (WAJIB) ----------
# Cloudflare R2 (S3-compatible) — gambar produk/brand/kategori & PDF invoice.
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ecommerce
# Base URL publik bucket (untuk me-resolve URL gambar/PDF di response).
R2_PUBLIC_URL=https://cdn.example.com

# ---------- Email / Resend (WAJIB) ----------
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Toko Anda <noreply@example.com>

# ---------- Identitas perusahaan (WAJIB — tampil di invoice) ----------
COMPANY_NAME=Toko Anda
COMPANY_ADDRESS=Jl. Contoh No. 1, Bandung
COMPANY_EMAIL=halo@example.com
COMPANY_PHONE=+62 812-0000-0000
COMPANY_LOGO_URL=https://cdn.example.com/logo.png

# ---------- Auth ----------
# WAJIB untuk login Google (GIS): OAuth Client ID tipe "Web application"
# dari Google Cloud Console — harus SAMA dengan client_id yang dipakai FE.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ---------- Payment ----------
# WAJIB untuk webhook payment (dummy gateway): secret HMAC-SHA256.
# Generate: openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=

# ---------- Order ----------
# Opsional. TTL pembayaran sebelum reservasi stok dilepas (default 30 menit).
ORDER_EXPIRATION_MINUTES=30

# ---------- Analytics ----------
# Opsional. Timezone bucket harian/mingguan/bulanan (default Asia/Jakarta).
ANALYTICS_TIMEZONE=Asia/Jakarta

# ---------- Tuning opsional ----------
# Kualitas konversi gambar ke WebP 1-100 (default mengikuti service).
IMAGE_WEBP_QUALITY=
# Path Chromium kustom untuk Puppeteer (kosongkan utk bawaan).
PUPPETEER_EXECUTABLE_PATH=
